#!/usr/bin/env bash

# Automated installer for vedantrathore/dotfiles using dotbot
# Usage:
#   ./install          - Interactive installation (prompts for options)
#   ./install minimal  - Core configs only (zsh, git, tmux)
#   ./install full     - Everything including Neovim, CLI tools, macOS settings

set -e

function pecho() {
    local PRINT_COLOR=6
    if [[ -n "$2" ]] ; then
        PRINT_COLOR=$2
    fi
    echo -ne "$(tput setaf "${PRINT_COLOR}")$1$(tput sgr0)"
}

function show_usage() {
    echo "Usage: ./install [profile]"
    echo ""
    echo "Profiles:"
    echo "  minimal  - Core configs only (zsh, git, tmux)"
    echo "  full     - Everything including Neovim, CLI tools, macOS settings"
    echo "  (none)   - Interactive installation with prompts"
    echo ""
}

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

DOTBOT_DIR="vendor/github/dotbot"
DOTBOT_BIN="bin/dotbot"

# Determine installation profile
PROFILE="${1:-}"

case "$PROFILE" in
    minimal)
        CONFIG="install.minimal.yaml"
        pecho "Running minimal installation...\n" 2
        ;;
    full)
        CONFIG="install.conf.yaml"
        pecho "Running full installation...\n" 2
        ;;
    -h|--help|help)
        show_usage
        exit 0
        ;;
    "")
        CONFIG="install.conf.yaml"
        pecho "Running interactive installation...\n" 2
        ;;
    *)
        pecho "Unknown profile: $PROFILE\n" 1
        show_usage
        exit 1
        ;;
esac

###############################################################################
# dotbot install
###############################################################################

pecho "Linking with dotbot:\n"

cd "${BASEDIR}"
git submodule update --init --recursive "${DOTBOT_DIR}"

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@:2}"

# Exit early for minimal installation
if [[ "$PROFILE" == "minimal" ]]; then
    pecho "\nMinimal installation complete!\n" 2
    pecho "Run './install full' for complete setup.\n"
    exit 0
fi

###############################################################################
# Powerline fonts
###############################################################################

pecho "Would you like to install powerline fonts ? [y/N] "
read -r response
if [[ $response =~ ^([yY][eE][sS]|[yY])$ ]]
then
    source "${BASEDIR}/vendor/github/fonts/install.sh"
else
    echo "Skipped installation of powerline fonts"
fi

###############################################################################
# Install zsh (oh-my-zsh) + plugins + themes
###############################################################################

pecho "Installing zsh (oh-my-zsh) + plugins + themes:\n"

if [ ! -d "$HOME/.oh-my-zsh" ] ; then

    echo "Installing Oh My Zsh"
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

    # shellcheck disable=SC1091
    source "$HOME/.zshrc"
else
    echo "Oh My Zsh already installed"
fi

###############################################################################
# Install brew + formulae (macOS only)
###############################################################################

## abort if not macOS
[[ "$OSTYPE" =~ ^darwin ]] || exit 0

## install homebrew + formulae?
pecho "Would you like to install Homebrew (http://brew.sh) + formulae + configure macOS settings? [y/N] "
read -r response ; tput sgr0
if [[ $response =~ ^([yY][eE][sS]|[yY])$ ]] ; then
    echo "Installing brew and formulae:"

    # brew installed?
    if ! command -v brew &> /dev/null ; then
        # install Homebrew
        echo "Installing brew:"
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    else
        echo "Brew already installed. Updating..."
        brew update
        brew upgrade
    fi

    # Double check we've installed brew correctly
    if command -v brew &> /dev/null ; then
        echo "Installing packages from Brewfile:"

        # Use Brewfile for declarative package management
        if [[ -f "${BASEDIR}/Brewfile" ]]; then
            brew bundle --file="${BASEDIR}/Brewfile" || true
        else
            pecho "Warning: Brewfile not found, skipping brew packages\n" 3
        fi

        brew cleanup
    else
        echo "Error installing brew... brew + packages not installed."
    fi

    ## Setup Mac Settings
    # shellcheck disable=SC1090
    source ~/.macos
fi

pecho "Done!\n" 2
